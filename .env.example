# Strava API Configuration
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# App URL (change in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Strava OAuth Callback URL (must match Strava app settings)
# Set this to: http://localhost:3000/api/strava/callback
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# Session secret for cookie signing (generate a random 32+ char string)
SESSION_SECRET=your-very-long-random-session-secret-here-min-32-chars

# Optional: Mapbox token for enhanced map tiles (falls back to SVG route)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_optional

# ── Railway export service ────────────────────────────────────────────────────
# URL of your deployed Railway export service
# Leave empty to use local Chromium fallback (not recommended on Vercel free)
EXPORT_SERVICE_URL=https://your-service.railway.app

# Must match API_SECRET in the Railway service (leave both blank to disable auth)
EXPORT_SERVICE_SECRET=change-me-to-a-random-string
